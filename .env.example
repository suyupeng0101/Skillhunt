# GitHub personal access token。
# 推荐配置，用于提高 GitHub API 限额，也可用于 GitHub Actions checkout/push。
PERSONAL_ACCESS_TOKENS=your_github_personal_access_token

# GitHub token 的兼容备用变量名；一般留空即可。
PERSONAL_ACCESS_TOKEN=

# 通用 OpenAI-compatible 模型配置。
# 模型配置与 radar 管道解耦：填任意 OpenAI-compatible Chat Completions 服务即可。
MODEL_PROVIDER=openai-compatible
MODEL_API_KEY=your_model_api_key
MODEL_API_BASE=
MODEL_NAME=
# MODEL_API_BASE 可以填 base URL，也可以填完整 /chat/completions endpoint。
# 示例：如果使用 qwen3.7-max，把 MODEL_API_BASE 填成对应服务商的 OpenAI-compatible 地址，并把 MODEL_NAME 设为 qwen3.7-max。

# 可选：流水线调参。
#
# 搜索召回配置：
# - Skill 和 Agent 使用不同 star 阈值，以减少低质量候选。
# - GITHUB_SEARCH_QUALIFIERS 会追加到每条 GitHub Search query 后面。
# SKILL_SEARCH_MIN_STARS=1000
# AGENT_SEARCH_MIN_STARS=2000
# GITHUB_SEARCH_QUALIFIERS=fork:false archived:false
# MAX_RESULTS_PER_QUERY=10
# GITHUB_SEARCH_PAGES=1

# 增长信号召回：
# - Trending 用于补充新增且增长较快、但总 star 可能还不高的项目。
# ENABLE_GITHUB_TRENDING=1
# GITHUB_TRENDING_PERIODS=daily,weekly
# GITHUB_TRENDING_FETCH_LIMIT=25

# 候选噪音过滤：
# - 这些过滤会在 README 拉取和模型调用之前执行，用于节省 API 配额并减少无关结果。
# - 设置 CANDIDATE_MAX_PUSH_AGE_DAYS=0 可以关闭长期未维护项目过滤。
# FILTER_ARCHIVED_REPOS=1
# FILTER_FORK_REPOS=1
# FILTER_TEMPLATE_REPOS=1
# FILTER_DISABLED_REPOS=1
# CANDIDATE_MAX_PUSH_AGE_DAYS=730
# CANDIDATE_NOISE_TERMS=awesome,curated-list,paper-list,papers,survey,benchmark,dataset,datasets,example,examples,demo,demos,tutorial,tutorials,course,courses

# README / 模型预算：
# - README_FETCH_LIMIT=0 表示为所有候选项目拉取 README。
# - 如果模型上下文过长，可降低 README_MAX_CHARS 或 MODEL_INPUT_CHAR_BUDGET。
# README_FETCH_LIMIT=0
# README_MAX_CHARS=1800
# HTTP_TIMEOUT=30
# MODEL_HTTP_TIMEOUT=300
# GITHUB_REQUEST_INTERVAL_SECONDS=0.2
# GITHUB_SEARCH_REQUEST_INTERVAL_SECONDS=2.2
# GITHUB_WAIT_ON_RATE_LIMIT=1
# GITHUB_RATE_LIMIT_RETRIES=2
# GITHUB_RATE_LIMIT_MAX_WAIT_SECONDS=120.0
# AI_BATCH_SIZE=2
# MODEL_INPUT_CHAR_BUDGET=22000
# MODEL_MAX_TOKENS=4096
# MODEL_REQUEST_INTERVAL_SECONDS=3.0
# MODEL_MAX_RETRIES=2
# MODEL_RETRY_BASE_SECONDS=2.0
# MODEL_RETRY_MAX_SECONDS=60.0
# MODEL_FAILURE_CIRCUIT_BREAKER=3
# LOG_LEVEL=DEBUG
# DEBUG_LOG_FILE=data/debug.log
